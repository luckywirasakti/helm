# HELM environment configuration
# Copy this file to `.env` and adjust values for your deployment.

# Port the HTTP and WebSocket server listens on.
HELM_PORT=20131

# HTTP Basic-Auth credentials. CHANGE THESE BEFORE EXPOSING THE PANEL.
# The REST API (/api/*) and WebSocket streams both authenticate with these.
HELM_USER=admin
HELM_PASS=change-me

# Optional: shell spawned for the web terminal (default: /bin/bash).
# SHELL=/bin/bash

# Optional: working directory for new terminal sessions (default: $HOME).
# HOME=/root

# Optional: filesystem path used for the disk usage metric.
#   Default "/" (works for a host install or a container with pid: host).
#   Set to e.g. "/hostfs" and bind-mount `- /:/hostfs:ro` in compose
#   when running HELM in a non-pid:host container — see docs/DOCKER.md.
# HELM_DISK_ROOT=/
